// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DifficultyLevel {
  easy
  medium
  hard
}

enum SessionStatus {
  DONE
  MISSED
  PARTIAL
}

enum AlertType {
  MISSED
  PAIN
  CONFUSION
}

enum Role {
  THERAPIST
  PATIENT
  ADMIN
}

enum ReminderChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

model User {
  id         String   @id @default(uuid())
  full_name  String
  email      String   @unique
  phone      String
  // Null until the account holder sets it (e.g. therapist invite flow) —
  // an account with no password cannot log in yet.
  password   String?
  role       Role
  created_at DateTime @default(now())

  // Patient-only fields
  diagnosis   String?
  enrolled_at DateTime @default(now())
  isVerified  Boolean  @default(false)

  // Device token for push notifications (FCM)
  fcm_token String?

  // Self-relation: the therapist assigned to a patient
  therapist_id String?
  therapist    User?  @relation("TherapistPatients", fields: [therapist_id], references: [id])
  patients     User[] @relation("TherapistPatients")

  programs         Program[]
  sessions         Session[]
  patient_alerts   Alert[]   @relation("PatientAlerts")
  therapist_alerts Alert[]   @relation("TherapistAlerts")
  reminders        Reminder[]
}

model Exercise {
  id              String          @id @default(uuid())
  name            String
  // Cached, short-lived playback URL (signed R2 URL, or an externally hosted URL)
  video_watch_url String?
  // Stable R2 object key backing video_watch_url — null when video_watch_url was set
  // manually (e.g. an external link) rather than uploaded, in which case it never expires
  video_path            String?
  video_url_expires_at  DateTime?
  // video_doit_url   String
  body_part       String
  procedure       String
  difficulty      DifficultyLevel @default(easy)

  progression      String
  exercise_img_url String?
  default_sets     Int    @default(3)
  default_reps     Int    @default(10)

  // Progression chain
  next_exercise_id  String?   @unique // points to the harder exercise
  next_exercise     Exercise? @relation("Progression", fields: [next_exercise_id], references: [id])
  previous_exercise Exercise? @relation("Progression")

  // How many completed sessions before auto-unlocking next level
  sessions_to_unlock_next Int @default(5)

  programs Program[]
}

model Program {
  id            String   @id @default(uuid())
  sets          Int
  reps          Int
  freq_per_week Int
  start_date    DateTime
  end_date      DateTime
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  // Last time a "do your exercises" reminder was sent for this program — dedupes to
  // one reminder per day
  last_reminded_at DateTime?

  patient_id String
  patient    User @relation(fields: [patient_id], references: [id])

  exercise_id String
  exercise    Exercise @relation(fields: [exercise_id], references: [id])

  sessions  Session[]
  reminders Reminder[]
}

model Session {
  id             String        @id @default(uuid())
  scheduled_date DateTime
  completed_at   DateTime?
  watch_demo     Boolean       @default(false)
  sets_done      Int           @default(0)
  pain_before    Int?
  pain_after     Int?
  confusion_flag Boolean       @default(false)
  status         SessionStatus @default(MISSED)
  created_at     DateTime      @default(now())

  patient_id String
  patient    User @relation(fields: [patient_id], references: [id])

  program_id String
  program    Program @relation(fields: [program_id], references: [id])
}

model Alert {
  id           String    @id @default(uuid())
  alert_type   AlertType
  triggered_at DateTime  @default(now())
  resolved     Boolean   @default(false)
  resolved_at  DateTime?

  patient_id String
  patient    User @relation("PatientAlerts", fields: [patient_id], references: [id])

  therapist_id String
  therapist    User @relation("TherapistAlerts", fields: [therapist_id], references: [id])
}

model Reminder {
  id       String            @id @default(uuid())
  message  String
  channels ReminderChannel[]
  read     Boolean           @default(false)
  sent_at  DateTime          @default(now())

  patient_id String
  patient    User @relation(fields: [patient_id], references: [id])

  program_id String?
  program    Program? @relation(fields: [program_id], references: [id])

  @@index([patient_id, read])
}

model RefreshTokenBlacklist {
  id        String   @id @default(uuid())
  reference String   @unique @db.VarChar(255)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FIX: changed name: to map: to match the convention used across the entire schema
  @@index([expiresAt], map: "idx_blacklist_expires")
  @@map("refresh_token_blacklist")
}

model AuthSession {
  id      String @id @default(uuid())
  user_id String

  last_accessed DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([last_accessed], map: "idx_auth_session_expires")
  @@map("auth_sessions")
}
