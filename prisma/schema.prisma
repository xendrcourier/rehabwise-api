// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  yo
  en
  ha
  ig
}

enum SessionStatus {
  DONE
  MISSED
  PARTIAL
}

enum AlertType {
  MISSED
  PAIN
  CONFUSION
}

enum Role {
  THERAPIST
  PATIENT
  ADMIN
}

model Therapist {
  id         String   @id @default(uuid())
  full_name  String
  email      String   @unique
  phone      String
  password   String
  role       Role     @default(THERAPIST)
  created_at DateTime @default(now())

  patients Patient[]
  alerts   Alert[]
}

model Patient {
  id          String   @id @default(uuid())
  full_name   String
  phone       String
  email       String   @unique
  password    String
  language    Language @default(en)
  diagnosis   String?
  enrolled_at DateTime @default(now())

  therapist_id String
  therapist    Therapist @relation(fields: [therapist_id], references: [id])

  programs Program[]
  sessions Session[]
  alerts   Alert[]
}

model Exercise {
  id              String @id @default(uuid())
  name_en         String
  name_yo         String
  video_watch_url String
  video_doit_url  String
  body_part       String
  default_sets    Int    @default(3)
  default_reps    Int    @default(10)

  programs Program[]
}

model Program {
  id            String   @id @default(uuid())
  sets          Int
  reps          Int
  freq_per_week Int
  start_date    DateTime
  end_date      DateTime
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  patient_id String
  patient    Patient @relation(fields: [patient_id], references: [id])

  exercise_id String
  exercise    Exercise @relation(fields: [exercise_id], references: [id])

  sessions Session[]
}

model Session {
  id             String        @id @default(uuid())
  scheduled_date DateTime
  completed_at   DateTime?
  watch_demo     Boolean       @default(false)
  sets_done      Int           @default(0)
  pain_before    Int?
  pain_after     Int?
  confusion_flag Boolean       @default(false)
  status         SessionStatus @default(MISSED)
  created_at     DateTime      @default(now())

  patient_id String
  patient    Patient @relation(fields: [patient_id], references: [id])

  program_id String
  program    Program @relation(fields: [program_id], references: [id])
}

model Alert {
  id           String    @id @default(uuid())
  alert_type   AlertType
  triggered_at DateTime  @default(now())
  resolved     Boolean   @default(false)
  resolved_at  DateTime?

  patient_id String
  patient    Patient @relation(fields: [patient_id], references: [id])

  therapist_id String
  therapist    Therapist @relation(fields: [therapist_id], references: [id])
}

model RefreshTokenBlacklist {
  id        String   @id @default(uuid())
  reference String   @unique @db.VarChar(255)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FIX: changed name: to map: to match the convention used across the entire schema
  @@index([expiresAt], map: "idx_blacklist_expires")
  @@map("refresh_token_blacklist")
}

model AuthSession {
  id      String @id @default(uuid())
  user_id String

  last_accessed DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([last_accessed], map: "idx_auth_session_expires")
  @@map("auth_sessions")
}
